{
  "id": "hospital",
  "title": "Government Hospital / Health Facility Inspection — Yadadri Bhuvanagiri District",
  "sections": [
    {
      "id": "hp1_facility",
      "title": "HP1 — Facility Details",
      "max_score": 0,
      "fields": [
        { "id": "facility_name",     "label": "Name of the Facility",                                           "type": "text",     "scored": false },
        { "id": "facility_type",     "label": "Facility Type",                                                  "type": "dropdown", "scored": false, "options": ["District Hospital", "CHC", "PHC", "UPHC", "Other"] },
        { "id": "mandal",            "label": "Mandal",                                                         "type": "text",     "scored": false },
        { "id": "address",           "label": "Address",                                                        "type": "text",     "scored": false },
        { "id": "inspecting_officer","label": "Name of Inspecting Officer",                                     "type": "text",     "scored": false },
        { "id": "inspection_date",   "label": "Date of Inspection",                                             "type": "date",     "scored": false },
        { "id": "inspection_time",   "label": "Time of Inspection",                                             "type": "text",     "scored": false }
      ]
    },
    {
      "id": "hp3_services",
      "title": "HP3 — Service Availability",
      "max_score": 15,
      "fields": [
        { "id": "opd_available",       "label": "OPD services functional",                  "type": "yes_no",       "scored": true, "weight": 2 },
        { "id": "ipd_available",       "label": "IPD / in-patient services functional",     "type": "yes_no_na",    "scored": true, "weight": 2 },
        { "id": "emergency_service",   "label": "Emergency / casualty services available",  "type": "yes_no_na",    "scored": true, "weight": 2 },
        { "id": "delivery_service",    "label": "Delivery / maternity services available",  "type": "yes_no_na",    "scored": true, "weight": 2, "show_for": ["dh", "chc"] },
        { "id": "lab_service",         "label": "Lab / diagnostic services available",      "type": "yes_no_na",    "scored": true, "weight": 2 },
        { "id": "pharmacy_service",    "label": "Pharmacy open and functional",             "type": "yes_no",       "scored": true, "weight": 2 },
        { "id": "ambulance_service",   "label": "Ambulance / referral transport available", "type": "yes_no_na",    "scored": true, "weight": 3 }
      ]
    },
    {
      "id": "s1_infra",
      "title": "HP4 — Infrastructure",
      "max_score": 15,
      "fields": [
        { "id": "opd_condition", "label": "OPD area condition", "type": "good_avg_poor", "scored": true, "weight": 2 },
        { "id": "ward_condition", "label": "Ward condition", "type": "good_avg_poor", "scored": true, "weight": 2 },
        { "id": "beds_sanctioned", "label": "Sanctioned bed strength", "type": "number", "scored": false },
        { "id": "beds_functional", "label": "Functional beds", "type": "number", "scored": false },
        { "id": "beds_clean", "label": "Beds and mattresses clean", "type": "good_avg_poor", "scored": true, "weight": 2 },
        { "id": "ot_functional", "label": "Operation theatre functional", "type": "yes_no_na", "scored": true, "weight": 3, "show_for": ["dh", "chc"] },
        { "id": "labour_room", "label": "Labour room functional", "type": "yes_no_na", "scored": true, "weight": 3, "show_for": ["dh", "chc"] },
        { "id": "casualty", "label": "Casualty / emergency area functional", "type": "yes_no", "scored": true, "weight": 3, "show_for": ["dh"] }
      ]
    },
    {
      "id": "s2_staff",
      "title": "HP2 — Human Resources & Staff",
      "max_score": 25,
      "fields": [
        {
          "id": "staff_table",
          "label": "Staff roster — sanctioned vs present",
          "type": "staff_table",
          "scored": true,
          "weight": 20,
          "dynamic_rows": true,
          "staff_roles": [
            { "id": "doctor", "label": "Doctor / Medical Officer" },
            { "id": "specialist", "label": "Specialist Doctor" },
            { "id": "nursing", "label": "Nursing Staff / ANM" },
            { "id": "lab_tech", "label": "Lab Technician" },
            { "id": "pharmacist", "label": "Pharmacist" },
            { "id": "ward_attendant", "label": "Ward Attendant / Aaya" },
            { "id": "cleaning", "label": "Cleaning / Sanitation Staff" },
            { "id": "security", "label": "Security Staff" }
          ]
        },
        { "id": "duty_roster_displayed", "label": "Duty roster displayed", "type": "yes_no", "scored": true, "weight": 2.5 },
        { "id": "duty_register", "label": "Duty register maintained", "type": "yes_no", "scored": true, "weight": 2.5 }
      ]
    },
    {
      "id": "s3_medicines",
      "title": "HP6 — Medicines & Equipment",
      "max_score": 25,
      "fields": [
        { "id": "essential_meds", "label": "Essential medicines available", "type": "avail_partial_na", "scored": true, "weight": 4 },
        { "id": "med_storage", "label": "Medicine storage condition", "type": "good_avg_poor", "scored": true, "weight": 3 },
        { "id": "expired_meds", "label": "Expired medicines found", "type": "yes_no", "scored": true, "weight": 4, "helper": "Yes is NON-compliant here" },
        { "id": "emergency_equipment", "label": "Emergency equipment available", "type": "avail_partial_na", "scored": true, "weight": 4 },
        { "id": "diag_equipment", "label": "Diagnostic equipment functional", "type": "good_avg_poor", "scored": true, "weight": 4 },
        { "id": "oxygen_supply", "label": "Oxygen supply available", "type": "yes_no", "scored": true, "weight": 3 },
        { "id": "ambulance", "label": "Ambulance availability", "type": "yes_no_na", "scored": true, "weight": 3 }
      ]
    },
    {
      "id": "s4_sanitation",
      "title": "HP5 — Cleanliness / Sanitation / IPC",
      "max_score": 15,
      "fields": [
        { "id": "ward_cleanliness", "label": "Ward cleanliness", "type": "good_avg_poor", "scored": true, "weight": 3 },
        { "id": "patient_toilets", "label": "Toilet facilities for patients", "type": "avail_partial_na", "scored": true, "weight": 2.5 },
        { "id": "toilet_cleanliness", "label": "Toilet cleanliness", "type": "good_avg_poor", "scored": true, "weight": 2.5 },
        { "id": "biowaste", "label": "Bio-medical waste disposal", "type": "good_avg_poor", "scored": true, "weight": 3 },
        { "id": "cleaning_schedule", "label": "Cleaning schedule displayed and maintained", "type": "yes_no", "scored": true, "weight": 2 },
        { "id": "campus_cleanliness", "label": "Overall hospital campus cleanliness", "type": "good_avg_poor", "scored": true, "weight": 2 }
      ]
    },
    {
      "id": "s5_records",
      "title": "HP8 — Registers & Governance",
      "max_score": 10,
      "fields": [
        { "id": "opd_register", "label": "OPD patient register maintained", "type": "yes_no", "scored": true, "weight": 1.5 },
        { "id": "ipd_register", "label": "IPD patient register maintained", "type": "yes_no", "scored": true, "weight": 1.5 },
        { "id": "referral_records", "label": "Referral records maintained", "type": "yes_no", "scored": true, "weight": 1.5 },
        { "id": "birth_records", "label": "Birth records maintained", "type": "yes_no_na", "scored": true, "weight": 2 },
        { "id": "death_records", "label": "Death records maintained", "type": "yes_no_na", "scored": true, "weight": 2 },
        { "id": "complaint_register", "label": "Complaint / feedback register available", "type": "yes_no", "scored": true, "weight": 1.5 }
      ]
    },
    {
      "id": "s6_utilities",
      "title": "HP7 — Labour Room / OT / Utilities & Safety",
      "max_score": 10,
      "fields": [
        { "id": "power_backup", "label": "Power backup / generator available", "type": "yes_no", "scored": true, "weight": 1.5 },
        { "id": "generator_functional", "label": "Generator functional", "type": "yes_no", "scored": true, "weight": 1.5 },
        { "id": "drinking_water", "label": "Drinking water for patients available", "type": "yes_no", "scored": true, "weight": 2 },
        { "id": "fire_safety", "label": "Fire safety equipment available", "type": "yes_no", "scored": true, "weight": 1.5 },
        { "id": "fire_valid", "label": "Fire equipment within validity", "type": "yes_no", "scored": true, "weight": 1.5 },
        { "id": "emergency_contacts", "label": "Emergency contact list displayed", "type": "yes_no", "scored": true, "weight": 2 }
      ]
    },
    {
      "id": "hp9_patient",
      "title": "HP9 — Patient / Citizen Service",
      "max_score": 10,
      "fields": [
        { "id": "grievance_mechanism", "label": "Grievance / complaint mechanism available",         "type": "yes_no",        "scored": true, "weight": 2 },
        { "id": "patient_water",       "label": "Drinking water available for patients",             "type": "yes_no",        "scored": true, "weight": 2 },
        { "id": "waiting_area",        "label": "Adequate waiting area for patients / attendants",   "type": "yes_no",        "scored": true, "weight": 2 },
        { "id": "help_desk",           "label": "Help desk / reception functional",                  "type": "yes_no_na",     "scored": true, "weight": 2 },
        { "id": "patient_toilet",      "label": "Patient toilet accessible and functional",          "type": "avail_partial_na","scored": true, "weight": 2 }
      ]
    },
    {
      "id": "hp10_findings",
      "title": "HP10 — Findings of the Inspecting Officer",
      "max_score": 0,
      "requires_remarks": true,
      "fields": [
        { "id": "critical_findings",   "label": "Critical findings observed",                        "type": "text",     "scored": false, "helper": "Describe critical non-compliances found during the inspection" },
        { "id": "severity",            "label": "Severity level",                                    "type": "dropdown", "scored": false, "options": ["Critical", "High", "Medium", "Low", "None"] },
        { "id": "compliance_action",   "label": "Compliance action required",                        "type": "text",     "scored": false },
        { "id": "reinspect_required",  "label": "Reinspection required",                             "type": "yes_no",   "scored": false },
        { "id": "escalation_required", "label": "Escalation to DMHO required",                      "type": "yes_no",   "scored": false }
      ]
    }
  ]
}
